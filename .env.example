# MongoDB Atlas connection string used by the csvToAtlas import CLI.
# Example: mongodb+srv://user:password@cluster0.example.mongodb.net
MONGODB_URI=

# Database name to import into. Optional; defaults to "csv_to_atlas".
MONGODB_DB=csv_to_atlas

# Optional: MongoDB Model Key (Voyage embeddings via Atlas Model API).
# When present, RAG uses hybrid retrieval: BM25 (exact keywords) + Voyage 4
# (conceptual context), merged with Reciprocal Rank Fusion.
# Create in Atlas: AI Services → Models → API Keys
# https://www.mongodb.com/docs/voyageai/api-and-clients/
MONGODB_MODEL_KEY=

# Optional: Model API settings (only used when MONGODB_MODEL_KEY is set).
MONGODB_MODEL_EMBEDDING_MODEL=voyage-4
# Atlas Model keys (al-…) default to https://ai.mongodb.com/v1 automatically.
# Voyage platform keys (pa-…) default to https://api.voyageai.com/v1.
# MONGODB_MODEL_BASE_URL=https://ai.mongodb.com/v1

# Optional: OpenAI-compatible API key. Used only when MONGODB_MODEL_KEY is unset.
# Enables vector-only retrieval (cosine similarity); otherwise BM25 only.
OPENAI_API_KEY=

# Optional: override the OpenAI embedding model and API base URL.
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1

# Set to "true" to force the ETL into dry-run mode (3 chunks of 1,000 records)
# regardless of CLI flags. A safety gate for production environments.
DRY_RUN=
