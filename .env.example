# MongoDB Atlas connection string used by the csvToAtlas import CLI.
# Example: mongodb+srv://user:password@cluster0.example.mongodb.net
MONGODB_URI=

# Database name to import into. Optional; defaults to "csv_to_atlas".
MONGODB_DB=csv_to_atlas

# Optional: Voyage API key. When present, RAG uses hybrid retrieval:
# BM25 (exact keywords) + Voyage 4 embeddings (conceptual context), merged
# with Reciprocal Rank Fusion. When absent, retrieval defaults to BM25 only.
# Get a key: https://docs.voyageai.com/docs/embeddings
VOYAGE_API_KEY=

# Optional: Voyage embedding settings (only used when VOYAGE_API_KEY is set).
VOYAGE_EMBEDDING_MODEL=voyage-4
# Voyage platform: https://api.voyageai.com/v1
# MongoDB Atlas Voyage: https://ai.mongodb.com/v1
VOYAGE_BASE_URL=https://api.voyageai.com/v1

# Optional: OpenAI-compatible API key. Used only when VOYAGE_API_KEY is unset.
# Enables vector-only retrieval (cosine similarity); otherwise BM25 only.
OPENAI_API_KEY=

# Optional: override the OpenAI embedding model and API base URL.
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1

# Set to "true" to force the ETL into dry-run mode (3 chunks of 1,000 records)
# regardless of CLI flags. A safety gate for production environments.
DRY_RUN=
