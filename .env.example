# MongoDB Atlas connection string used by the csvToAtlas import CLI.
# Example: mongodb+srv://user:password@cluster0.example.mongodb.net
MONGODB_URI=

# Database name to import into. Optional; defaults to "csv_to_atlas".
MONGODB_DB=csv_to_atlas

# Optional: OpenAI-compatible API key. When present, the RAG retriever can
# embed knowledge-base chunks and store them in Atlas for $vectorSearch.
# When absent, the retriever falls back to deterministic lexical (BM25) scoring.
OPENAI_API_KEY=

# Optional: override the embedding model and API base URL.
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1

# Set to "true" to force the ETL into dry-run mode (3 chunks of 1,000 records)
# regardless of CLI flags. A safety gate for production environments.
DRY_RUN=
