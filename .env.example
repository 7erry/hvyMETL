# Required: path to a local clone of csvToAtlas (https://github.com/7erry/cvsToAtlas).
# ETL manifests and `npm run import-cli` invoke this installation. Build it first:
#   git clone https://github.com/7erry/cvsToAtlas.git && cd cvsToAtlas && npm install && npm run build
CSV_TO_ATLAS_PATH=/Users/you/projects/cvsToAtlas

# MongoDB Atlas connection string used by the csvToAtlas import CLI.
# Example: mongodb+srv://user:password@cluster0.example.mongodb.net
MONGODB_URI=

# Database name to import into. Optional; defaults to "csv_to_atlas".
MONGODB_DB=csv_to_atlas

# Optional: MongoDB Model Key (Voyage embeddings via Atlas Model API).
# When present, RAG uses hybrid retrieval: BM25 (exact keywords) + Voyage 4
# (conceptual context), merged in-process by hvyMETL's reciprocalRankFusion()
# (not Atlas hybrid search). See docs/03-knowledge-rag.md § RRF.
# Create in Atlas: AI Services → Models → API Keys
# https://www.mongodb.com/docs/voyageai/api-and-clients/
MONGODB_MODEL_KEY=

# Optional: Model API settings (only used when MONGODB_MODEL_KEY is set).
MONGODB_MODEL_EMBEDDING_MODEL=voyage-4
# Atlas Model keys (al-…) default to https://ai.mongodb.com/v1 automatically.
# Voyage platform keys (pa-…) default to https://api.voyageai.com/v1.
# MONGODB_MODEL_BASE_URL=https://ai.mongodb.com/v1

# Optional: OpenAI-compatible API key. Used only when MONGODB_MODEL_KEY is unset.
# Enables vector-only retrieval (cosine similarity); otherwise BM25 only.
OPENAI_API_KEY=

# Optional: override the OpenAI embedding model and API base URL.
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: default directory of CSV exports for the web UI full pipeline (design → csvToAtlas import).
# Export tables from your source database (PostgreSQL, MySQL, Oracle, etc.) as CSV files.
# Can also provide a path, upload CSVs in the pipeline dialog, or enable mock CSV generation from DDL.
HVYMETL_CSV_SOURCE=/Users/you/projects/csv-exports

# Optional: Python executable for mock CSV generation (generators/ddl_csv_generator.py).
# Requires: pip install -r generators/requirements.txt
# HVYMETL_PYTHON=python3

# Optional: Migration Studio API port (default 3847).
# HVYMETL_UI_PORT=3847

# Built-in example DDL for Migration Studio "Load example" (default: ~/hvymetl/examples, else repo examples/)
# HVYMETL_EXAMPLES_DIR=/home/deploy/hvymetl/examples

# Optional: database for ML metadata (migration logs, lessons learned, pipeline execution archive).
# Separate from MONGODB_DB (csvToAtlas import target). Default: hvymetl_memory
# HVYMETL_MEMORY_DB=hvymetl_memory

# Optional: skip Atlas import in npm run run-all-examples (design + ETL still run).
# HVYMETL_SKIP_ATLAS_IMPORT=1

# Optional: stub Atlas performance metrics for local ML reflection testing (healthy | degraded).
# HVYMETL_ATLAS_STUB_MODE=degraded

# Set to "true" to force the ETL into dry-run mode (3 chunks of 1,000 records)
# regardless of CLI flags. A safety gate for production environments.
DRY_RUN=

# Optional: set to 1 to disable the once-per-day CLI heartbeat (phone-home).
# HVYMETL_DISABLE_PHONE_HOME=1

# --- Hosted Migration Studio auth (https://hvymetl.studio) ---
# Leave unset for local development without login. Set issuer + audience for Auth0 JWT validation.
# AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.us.auth0.com/
# AUTH0_AUDIENCE=https://api.hvymetl.studio
# AUTH0_SPA_CLIENT_ID=your_spa_client_id
# AUTH0_ROLES_CLAIM=https://hvymetl.studio/roles
# Optional: set to 1 to bypass auth middleware locally while testing hosted UI flows.
# HVYMETL_AUTH_DISABLED=1
# When Auth0 is enabled but tokens lack role claims, default signed-in users to this role.
# Use "none" to require explicit Auth0 roles (Access pending until Login Action works).
# HVYMETL_DEFAULT_ROLE=developer
# Comma-separated Auth0 user IDs (JWT sub) that receive admin when the token has no roles claim.
# HVYMETL_ADMIN_SUBS=google-oauth2|104005738020757337481

# --- MongoDB Atlas Admin API (Manager View logs) ---
# Service account with Organization Project Owner or sufficient project access.
# Create in Atlas: Access Manager → Service Accounts → Add Service Account.
# ATLAS_CLIENT_ID=mdb_sa_id_…
# ATLAS_CLIENT_SECRET=mdb_sa_sk_…
# ATLAS_GROUP_ID=your_atlas_project_id
# Optional: per-node FQDN for mongod/mongos log download (not the cluster connection hostname).
# Example: mycluster-shard-00-00.abc12.mongodb.net — not mycluster.abc12.mongodb.net
# ATLAS_NODE_HOSTNAME=cluster0-shard-00-00.abc12.mongodb.net

# Web UI Auth0 settings (build-time Vite env vars — set in web/.env.local or deployment env):
# VITE_AUTH0_DOMAIN=YOUR_TENANT.us.auth0.com
# VITE_AUTH0_CLIENT_ID=your_spa_client_id
# VITE_AUTH0_AUDIENCE=https://api.hvymetl.studio
# VITE_AUTH0_ROLES_CLAIM=https://hvymetl.studio/roles
# Auth0 allowed callback/logout URLs: http://localhost:3847, https://hvymetl.studio
